---
import { NavItems } from '@/constant/sites.contant.ts';
import { SidebarHiddenButton } from '@/components/sideBarHiddenButton.component';
const currentPath = Astro.url.pathname;
const ids = ['side-bar-hidde-element','side-bar-hidde-element-nav','side-bar-hidde-element-info'];
const localStorageKey = 'side-bar-local-storage-visibility';

---
<aside class="border-sidebar-border bg-sidebar/80 text-sidebar-foreground flex h-full flex-col border-r backdrop-blur">
	<div class="flex flex-row border-sidebar-border border-b">
		<a id="side-bar-hidde-element" href="/" class="flex items-center gap-3 px-5 py-5">
			<span class="bg-sidebar-primary text-sidebar-primary-foreground grid size-9 place-items-center rounded-lg text-sm font-semibold">
				DU
			</span>
				<span class="min-w-0">
				<span class="block text-sm font-semibold tracking-tight">Dev Utils</span>
				<span class="text-muted-foreground block text-xs">Static developer tools</span>
			</span>
		</a>
		<SidebarHiddenButton
			localStorageKey={localStorageKey}
			idsToClear={ids}
			client:load
		/>
	</div>
	<nav id="side-bar-hidde-element-nav" aria-label="Developer tools" class="flex flex-1 flex-col gap-1 p-3 hidden">
		{NavItems.map((item) => {
			const isActive = item.href !== '#' && currentPath.startsWith(item.href);

			return item.isReady ? (
				<a
					href={item.href}
					aria-current={isActive ? 'page' : undefined}
					class:list={[
						'group rounded-lg px-3 py-2.5 transition-colors',
						isActive
							? 'bg-sidebar-primary text-sidebar-primary-foreground shadow-sm'
							: 'hover:bg-sidebar-accent hover:text-sidebar-accent-foreground',
					]}
				>
					<span class="flex items-center justify-between gap-3">
						<span class="font-medium">{item.label}</span>
						<span class:list={[
							'rounded-full px-2 py-0.5 text-[10px] uppercase tracking-wide',
							isActive ? 'bg-sidebar-primary-foreground/15' : 'bg-muted text-muted-foreground',
						]}>
							Tool
						</span>
					</span>
					<span class:list={[
						'mt-1 block text-xs',
						isActive ? 'text-sidebar-primary-foreground/75' : 'text-muted-foreground',
					]}>
						{item.description}
					</span>
				</a>
			) : (
				<div class="text-muted-foreground rounded-lg px-3 py-2.5 opacity-70">
					<span class="flex items-center justify-between gap-3">
						<span class="font-medium">{item.label}</span>
						<span class="bg-muted rounded-full px-2 py-0.5 text-[10px] uppercase tracking-wide">Soon</span>
					</span>
					<span class="mt-1 block text-xs">{item.description}</span>
				</div>
			);
		})}
	</nav>

	<div id="side-bar-hidde-element-info" class="border-sidebar-border text-muted-foreground border-t p-4 text-xs hidden">
		Tools run locally in the browser.
	</div>
</aside>
