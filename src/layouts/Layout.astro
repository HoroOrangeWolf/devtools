---
import '@/styles/global.css';
import SiteSidebar from '@/components/SiteSidebar.astro';

interface Props {
	title?: string;
	description?: string;
	keywords?: string[];
	canonicalPath?: string;
	ogImage?: string;
	structuredData?: Record<string, unknown>;
}

const {
	title = 'Dev Utils',
	description = 'A static collection of small developer utilities that run locally in your browser.',
	keywords = [
		'developer tools',
		'browser developer utilities',
		'local dev tools',
		'static developer toolbox',
	],
	canonicalPath = Astro.url.pathname,
	ogImage,
	structuredData,
} = Astro.props;

const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const canonicalUrl = new URL(canonicalPath, siteUrl).toString();
const pageUrl = canonicalUrl;
const imageUrl = ogImage ? new URL(ogImage, siteUrl).toString() : undefined;
const metaTitle = title.includes('Dev Utils') ? title : `${title} | Dev Utils`;
---
<!doctype html>
<html lang="en" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords.join(', ')} />
		<meta name="robots" content="index, follow, max-image-preview:large" />
		<link rel="canonical" href={canonicalUrl} />
		<meta name="theme-color" content="#1f1d1b" />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Dev Utils" />
		<meta property="og:title" content={metaTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={pageUrl} />
		{imageUrl && <meta property="og:image" content={imageUrl} />}
		<meta name="twitter:card" content={imageUrl ? 'summary_large_image' : 'summary'} />
		<meta name="twitter:title" content={metaTitle} />
		<meta name="twitter:description" content={description} />
		{imageUrl && <meta name="twitter:image" content={imageUrl} />}
		{structuredData && (
			<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
		)}
		<title>{metaTitle}</title>
	</head>
	<body class="bg-background text-foreground min-h-screen">
		<div class="grid min-h-screen lg:flex lg:flex-row">
			<div class="hidden lg:block">
				<SiteSidebar />
			</div>

			<div class="flex min-w-0 flex-col">
				<header class="border-border bg-background/85 sticky top-0 z-20 border-b backdrop-blur">
					<div class="flex min-h-16 items-center justify-between gap-4 px-4 sm:px-6 lg:px-8">
						<a href="/" class="flex items-center gap-3 lg:hidden">
							<span class="bg-primary text-primary-foreground grid size-8 place-items-center rounded-lg text-xs font-semibold">
								DU
							</span>
							<span class="font-semibold">Dev Utils</span>
						</a>

						<div class="hidden lg:block">
							<p class="text-muted-foreground text-xs uppercase tracking-[0.18em]">Developer toolbox</p>
							<h1 class="text-lg font-semibold tracking-tight">Dev Utils</h1>
						</div>

						<nav aria-label="Mobile tools" class="flex items-center gap-2 lg:hidden">
							<a
								href="/uuid"
								class="bg-secondary text-secondary-foreground rounded-lg px-3 py-1.5 text-sm font-medium"
							>
								UUID
							</a>
						</nav>
					</div>
				</header>

				<main class="flex-1 px-4 py-6 sm:px-6 lg:px-8 lg:py-8">
					<div class="mx-auto w-full max-w-10/12">
						<slot/>
					</div>
				</main>
			</div>
		</div>
		<script is:inline>
			const applySidebarVisibility = () => {
				try {
					const isSidebarHidden = window.localStorage.getItem('dev-utils:sidebar-hidden') === 'true';
					document.documentElement.dataset.sidebarHidden = isSidebarHidden ? 'true' : 'false';
				} catch {
					document.documentElement.dataset.sidebarHidden = 'false';
				}
			};

			applySidebarVisibility();
			window.addEventListener('storage', applySidebarVisibility);
			window.addEventListener('devutils:sidebar-visibility', applySidebarVisibility);
		</script>
		<style is:global>
			html[data-sidebar-hidden='true'] .site-shell {
				grid-template-columns: minmax(0, 1fr);
			}

			html[data-sidebar-hidden='true'] .site-sidebar-shell {
				display: none;
			}
		</style>
	</body>
</html>
