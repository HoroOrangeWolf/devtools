---
import Layout from '@/layouts/Layout.astro';
import { UuidRoot } from '@/container/uuid/uuid.root';

const title = 'UUID Generator and CSV Export Tool | Dev Utils';
const description =
	'Generate UUID v1, v4, v6, and v7 values locally in your browser, create batches, and export the generated identifiers as CSV.';
const keywords = [
	'UUID generator',
	'UUID v4 generator',
	'UUID v7 generator',
	'GUID generator',
	'batch UUID generator',
	'local UUID tool',
	'UUID CSV export',
	'developer ID generator',
];
---
<Layout
	title={title}
	description={description}
	keywords={keywords}
	canonicalPath="/uuid"
	structuredData={{
		'@context': 'https://schema.org',
		'@type': 'WebApplication',
		name: 'UUID Generator and CSV Export Tool',
		applicationCategory: 'DeveloperApplication',
		operatingSystem: 'Any',
		browserRequirements: 'Requires a modern browser with JavaScript enabled.',
		description,
		url: new URL('/uuid', Astro.site ?? Astro.url.origin).toString(),
		isAccessibleForFree: true,
		featureList: [
			'Generate UUID v1, v4, v6, and v7 values',
			'Create batches of unique identifiers',
			'Run generation locally in the browser',
			'Export generated UUID values as CSV',
			'Use generated IDs in development, testing, and data fixtures',
		],
		offers: {
			'@type': 'Offer',
			price: '0',
			priceCurrency: 'USD',
		},
	}}
>
	<section class="space-y-6">
		<div class="space-y-2">
			<p class="text-primary text-sm font-medium">Generator</p>
			<h2 class="text-2xl font-semibold tracking-tight">UUID Generator</h2>
			<p class="text-muted-foreground text-sm">
				Generate UUID values locally and export the result as CSV.
			</p>
		</div>

		<div class="border-border bg-card text-card-foreground rounded-lg border p-4 sm:p-6">
			<UuidRoot client:load />
		</div>
	</section>
</Layout>
