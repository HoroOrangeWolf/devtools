---
import Layout from '@/layouts/Layout.astro';
import { PdfRoot } from '@/container/pdf/pdf.root.tsx';

const title = 'PDF Merger and Page Organizer Tool | Dev Utils';
const description =
    'Merge PDF files, reorder, preview, swap, and remove pages locally in your browser without uploading documents.';
const keywords = [
    'PDF merger',
    'PDF page organizer',
    'reorder PDF pages',
    'remove PDF pages',
    'merge PDF files',
    'local PDF tool',
    'browser PDF editor',
    'PDF utility',
];
---
<Layout
        title={title}
        description={description}
        keywords={keywords}
        canonicalPath="/pdf"
        structuredData={{
            '@context': 'https://schema.org',
            '@type': 'WebApplication',
            name: 'PDF Merger and Page Organizer Tool',
            applicationCategory: 'DeveloperApplication',
            operatingSystem: 'Any',
            browserRequirements: 'Requires a modern browser with JavaScript enabled.',
            description,
            url: new URL('/pdf', Astro.site ?? Astro.url.origin).toString(),
            isAccessibleForFree: true,
            featureList: [
                'Merge multiple PDF files in the browser',
                'Reorder PDF pages with drag and drop',
                'Preview, swap, and remove PDF pages',
                'Download the organized PDF document',
                'Process PDF files locally without server upload',
            ],
            offers: {
                '@type': 'Offer',
                price: '0',
                priceCurrency: 'USD',
            },
        }}
>
    <section class="space-y-6">
        <div class="space-y-2">
            <p class="text-primary text-sm font-medium">PDF</p>
            <h2 class="text-2xl font-semibold tracking-tight">PDF Merger and Page Organizer</h2>
            <p class="text-muted-foreground text-sm">
                Merge and organize PDF pages locally in your browser.
            </p>
        </div>

        <div class="border-border bg-card text-card-foreground rounded-lg border p-4 sm:p-6">
            <PdfRoot client:load />
        </div>
    </section>
</Layout>
