---
import Layout from '@/layouts/Layout.astro';
import { PdfRoot } from '@/container/pdf/pdf.root.tsx';

const title = 'JSON Formatter and Converter Tool | Dev Utils';
const description =
    'Format, validate, and convert JSON to XML or CSV locally in your browser without uploading data.';
const keywords = [
    'JSON formatter',
    'JSON beautifier',
    'JSON validator',
    'JSON to XML converter',
    'JSON to CSV converter',
    'local JSON tool',
    'browser JSON formatter',
    'developer JSON utility',
];

// TODO: Ogarnąć to
---
<Layout
        title={title}
        description={description}
        keywords={keywords}
        canonicalPath="/jsonformatter"
        structuredData={{
            '@context': 'https://schema.org',
            '@type': 'WebApplication',
            name: 'JSON Formatter and Converter Tool',
            applicationCategory: 'DeveloperApplication',
            operatingSystem: 'Any',
            browserRequirements: 'Requires a modern browser with JavaScript enabled.',
            description,
            url: new URL('/jsonformatter', Astro.site ?? Astro.url.origin).toString(),
            isAccessibleForFree: true,
            featureList: [
                'Format and beautify JSON in the browser',
                'Validate JSON input',
                'Convert JSON to XML or CSV',
                'Choose compact or beautified output',
                'Process data locally without server upload',
            ],
            offers: {
                '@type': 'Offer',
                price: '0',
                priceCurrency: 'USD',
            },
        }}
>
    <section class="space-y-6">
        <div class="space-y-2">
            <p class="text-primary text-sm font-medium">Formatter</p>
            <h2 class="text-2xl font-semibold tracking-tight">JSON Formatter</h2>
            <p class="text-muted-foreground text-sm">
                Format and beautify JSON locally in your browser.
            </p>
        </div>

        <div class="border-border bg-card text-card-foreground rounded-lg border p-4 sm:p-6">
            <PdfRoot client:load />
        </div>
    </section>
</Layout>
