
---
import Layout from '@/layouts/Layout.astro';
import { UnixRoot } from '@/container/unix/unix.root.tsx';

const title = 'Unix Timestamp Converter | Dev Utils';
const description =
    'Convert Unix timestamps to readable dates and times, or turn dates into Unix timestamps locally in your browser.';
const keywords = [
    'Unix timestamp converter',
    'Unix time converter',
    'epoch converter',
    'timestamp to date',
    'date to timestamp',
    'epoch time converter',
    'local timestamp tool',
    'developer time utility',
];
---
<Layout
        title={title}
        description={description}
        keywords={keywords}
        canonicalPath="/unixTimestamp"
        structuredData={{
            '@context': 'https://schema.org',
            '@type': 'WebApplication',
            name: 'Unix Timestamp Converter',
            applicationCategory: 'DeveloperApplication',
            operatingSystem: 'Any',
            browserRequirements: 'Requires a modern browser with JavaScript enabled.',
            description,
            url: new URL('/unixTimestamp', Astro.site ?? Astro.url.origin).toString(),
            isAccessibleForFree: true,
            featureList: [
                'Convert Unix timestamps to readable dates and times',
                'Convert dates and times to Unix timestamps',
                'Display timestamp details in a selected time zone',
                'Process date and time values locally in the browser',
            ],
            offers: {
                '@type': 'Offer',
                price: '0',
                priceCurrency: 'USD',
            },
        }}
>
    <section class="space-y-6">
        <div class="space-y-2">
            <p class="text-primary text-sm font-medium">CSV</p>
            <h2 class="text-2xl font-semibold tracking-tight">Utils</h2>
            <p class="text-muted-foreground text-sm">
                Parse CSV, change CSV options and export to JSON.
            </p>
        </div>

        <div class="border-border bg-card text-card-foreground rounded-lg border p-4 sm:p-6">
            <UnixRoot client:load />
        </div>
    </section>
</Layout>
