---
import Layout from '@/layouts/Layout.astro';
import { JwtRoot } from '@/container/jwt/jwt.root.tsx';

const title = 'JWT Decoder, Encoder and Signature Verifier | Dev Utils';

const description =
    'Decode, inspect, sign, and verify JSON Web Tokens locally in your browser with support for HMAC, RSA, ECDSA, and EdDSA algorithms.';

const keywords = [
    'JWT decoder',
    'JWT encoder',
    'JWT verifier',
    'JWT signature verifier',
    'JSON Web Token debugger',
    'JWT parser',
    'JWT generator',
    'local JWT tool',
];

---
<Layout
        title={title}
        description={description}
        keywords={keywords}
        canonicalPath="/jwt"
        structuredData={{
            '@context': 'https://schema.org',
            '@type': 'WebApplication',
            name: 'JWT Decoder, Encoder and Signature Verifier',
            applicationCategory: 'DeveloperApplication',
            operatingSystem: 'Any',
            browserRequirements: 'Requires a modern browser with JavaScript enabled.',
            description,
            url: new URL('/jwt', Astro.site ?? Astro.url.origin).toString(),
            isAccessibleForFree: true,
            featureList: [
                'Decode JWT headers and payloads',
                'Verify JWT signatures with a secret or public key',
                'Create and sign JSON Web Tokens',
                'Support HMAC, RSA, RSA-PSS, ECDSA, and EdDSA signing algorithms',
                'Process tokens locally in the browser',
            ],
            offers: {
                '@type': 'Offer',
                price: '0',
                priceCurrency: 'USD',
            },
        }}
>
    <section class="space-y-6">
        <div class="space-y-2">
            <p class="text-primary text-sm font-medium">Token tool</p>
            <h2 class="text-2xl font-semibold tracking-tight">JWT Decoder and Encoder</h2>
            <p class="text-muted-foreground text-sm">
                Decode, verify, and sign JSON Web Tokens locally in your browser.
            </p>
        </div>

        <div class="border-border bg-card text-card-foreground rounded-lg border p-4 sm:p-6">
            <JwtRoot client:load />
        </div>
    </section>
</Layout>
