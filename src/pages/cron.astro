---
import Layout from '@/layouts/Layout.astro';
import { CronRoot } from '@/container/cron/cron.root.tsx';

const title = 'Cron Expression Generator for Unix and Quartz | Dev Utils';
const description =
    'Build, edit, validate, and explain Unix and Quartz cron expressions in your browser, with an execution preview coming soon.';
const keywords = [
    'cron expression generator',
    'cron schedule builder',
    'cron expression parser',
    'Unix cron generator',
    'Quartz cron generator',
    'cron expression validator',
    'cron expression editor',
    'cron expression explainer',
    'cron execution preview',
];
---
<Layout
        title={title}
        description={description}
        keywords={keywords}
        canonicalPath="/cron"
        structuredData={{
            '@context': 'https://schema.org',
            '@type': 'WebApplication',
            name: 'Cron Expression Generator for Unix and Quartz',
            applicationCategory: 'DeveloperApplication',
            operatingSystem: 'Any',
            browserRequirements: 'Requires a modern browser with JavaScript enabled.',
            description,
            url: new URL('/cron', Astro.site ?? Astro.url.origin).toString(),
            isAccessibleForFree: true,
            featureList: [
                'Build Unix cron expressions',
                'Build Quartz cron expressions',
                'Edit and validate individual cron fields',
                'Convert cron expressions into readable descriptions',
                'Copy generated cron expressions to the clipboard',
                'Upcoming preview of scheduled execution times',
            ],
            offers: {
                '@type': 'Offer',
                price: '0',
                priceCurrency: 'USD',
            },
        }}
>
    <section class="space-y-6">
        <div class="space-y-2">
            <p class="text-primary text-sm font-medium">Generator</p>
            <h2 class="text-2xl font-semibold tracking-tight">Cron Expression Generator</h2>
            <p class="text-muted-foreground text-sm">
                Build, validate, and explain Unix and Quartz cron expressions. Execution preview is
                coming soon.
            </p>
        </div>

        <div class="border-border bg-card text-card-foreground rounded-lg border p-4 sm:p-6">
            <CronRoot client:load />
        </div>
    </section>
</Layout>
