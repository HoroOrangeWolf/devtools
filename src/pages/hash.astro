---
import Layout from '@/layouts/Layout.astro';
import { HashRoot } from '@/container/hash/hash.root.tsx';

const title = 'Hash Generator for SHA, MD5, bcrypt and Argon2 | Dev Utils';
const description =
    'Generate SHA, SHA-3, MD5, bcrypt, and Argon2 hashes from text or files locally in your browser.';
const keywords = [
    'hash generator',
    'SHA-256 generator',
    'SHA-3 generator',
    'MD5 generator',
    'bcrypt generator',
    'Argon2 generator',
    'file hash generator',
    'local hashing tool',
];
---
<Layout
        title={title}
        description={description}
        keywords={keywords}
        canonicalPath="/hash"
        structuredData={{
            '@context': 'https://schema.org',
            '@type': 'WebApplication',
            name: 'Hash Generator for SHA, MD5, bcrypt and Argon2',
            applicationCategory: 'DeveloperApplication',
            operatingSystem: 'Any',
            browserRequirements: 'Requires a modern browser with JavaScript enabled.',
            description,
            url: new URL('/hash', Astro.site ?? Astro.url.origin).toString(),
            isAccessibleForFree: true,
            featureList: [
                'Generate SHA-2 and SHA-3 hashes',
                'Generate MD5 hashes',
                'Generate bcrypt password hashes with configurable options',
                'Generate Argon2d, Argon2i, and Argon2id hashes with configurable options',
                'Hash text or uploaded file content locally in the browser',
                'Download generated hashes as a text file',
            ],
            offers: {
                '@type': 'Offer',
                price: '0',
                priceCurrency: 'USD',
            },
        }}
>
    <section class="space-y-6">
        <div class="space-y-2">
            <p class="text-primary text-sm font-medium">Generator</p>
            <h2 class="text-2xl font-semibold tracking-tight">Hash Generator</h2>
            <p class="text-muted-foreground text-sm">
                Generate hashes from text or files locally in your browser.
            </p>
        </div>

        <div class="border-border bg-card text-card-foreground rounded-lg border p-4 sm:p-6">
            <HashRoot client:load />
        </div>
    </section>
</Layout>
